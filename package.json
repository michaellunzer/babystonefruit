{
    "author": "Michael Lunzer",
    "dependencies": {
        "@moddable/pebbleproxy": "^0.1.0"
    },
    "keywords": [
        "pebble-app"
    ],
    "name": "baby-stonefruit",
    "pebble": {
        "capabilities": [
            "configurable"
        ],
        "displayName": "Baby StoneFruit",
        "enableMultiJS": true,
        "messageKeys": [
            "ACTION",
            "RESULT",
            "STATUS",
            "MESSAGE",
            "LAST_DIAPER",
            "LAST_BOTTLE",
            "NURSING_STATE",
            "NURSING_START",
            "NURSING_LAST",
            "NURSING_ELAPSED"
        ],
        "projectType": "moddable",
        "resources": {
            "media": [
                { "type": "bitmap", "name": "IMAGE_DIAPER", "file": "img/poop.png" },
                { "type": "bitmap", "name": "IMAGE_BOTTLE", "file": "img/bottle.png" },
                { "type": "bitmap", "name": "IMAGE_NURSE",  "file": "img/nursing.png" },
                { "type": "bitmap", "name": "IMAGE_STOP",   "file": "img/stop.png" },
                { "type": "raw",    "name": "SOUND_UI_CONFIRM", "file": "audio/ui_confirm.pcm", "targetPlatforms": ["emery"] }
            ]
        },
        "sdkVersion": "3",
        "targetPlatforms": [
            "emery",
            "gabbro"
        ],
        "uuid": "980a7e4c-95e1-4c26-a156-7b67399b2771",
        "watchapp": {
            "watchface": false
        }
    },
    "version": "1.0.1"
}

// HA_URL: your Home Assistant URL (no trailing slash, https required if remote)
// HA_TOKEN: long-lived access token from HA Profile -> Security
export const HA_URL   = "https://home.example.com";
export const HA_TOKEN = "eyJhbGciOi...";

// CHILDREN: one entry per child. If more than one, the watch shows a
// "Child: <name>" cycle item at the top of the action list and remembers
// the last pick across launches.
export const CHILDREN = [
  { name: "Stone Fruit", deviceId: "abcdef0123456789..." },
  // { name: "Sibling",  deviceId: "..." },
];
